{
  "name": "ayur-taila-ai",
  "version": "1.0.0",
  "description": "AI-powered Ayurvedic diagnostic system using Taila Bindu Pariksha",
  "scripts": {
    "install-all": "npm run install-frontend && npm run install-backend && npm run install-ai",
    "install-frontend": "cd frontend && npm install",
    "install-backend": "cd backend && npm install",
    "install-ai": "cd ai-service && pip install -r requirements.txt",
    "start": "concurrently \"npm run start-backend\" \"npm run start-ai\" \"npm run start-frontend\"",
    "start-frontend": "cd frontend && npm start",
    "start-backend": "cd backend && npm run dev",
    "start-ai": "cd ai-service && python app.py",
    "build": "npm run build-frontend && npm run build-backend",
    "build-frontend": "cd frontend && npm run build",
    "build-backend": "cd backend && npm run build",
    "vercel-build": "npm run build-frontend"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "mongodb-memory-server": "^11.0.1"
  },
  "keywords": [
    "ayurveda",
    "healthcare",
    "ai",
    "diagnostic",
    "taila-bindu-pariksha",
    "dosha",
    "machine-learning",
    "computer-vision"
  ],
  "author": "AyurTaila AI Team",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1"
  }
}
